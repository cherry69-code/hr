############################
# Root-level ignore for monorepo
############################

# Node
backend/node_modules/
frontend/node_modules/
npm-debug.log*
yarn-error.log*

# Environments / Secrets
backend/.env
frontend/.env
backend/.env.local
backend/.env.development
backend/.env.production
frontend/.env.local
frontend/.env.development
frontend/.env.production

# Angular build artifacts and cache
frontend/dist/
frontend/.angular/

# platform-ts build artifacts
platform-ts/**/dist/

# legacy platform folder (generated/unused)
platform/

# Generated uploads and PDFs
backend/uploads/
backend/utils/*.pdf

# Zip and archives
*.zip
*.tar
*.tgz

# Coverage and temp
coverage/
tmp/
temp/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
node_modules
