# Backend environment (example - DO NOT COMMIT REAL SECRETS)
NODE_ENV=production
PORT=10000

# MongoDB
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?appName=<app>

# Migration (used only when running scripts/migrate_db.js)
MIGRATE_SOURCE_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?appName=<app>
MIGRATE_DEST_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?appName=<app>

# Auth
JWT_SECRET=replace-me
JWT_EXPIRE=30d

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me

# SMTP
SMTP_HOST=replace-me
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=replace-me
SMTP_PASSWORD=replace-me
FROM_EMAIL=hr@yourdomain.com
FROM_NAME=PropNinja HR

# URLs
FRONTEND_URL=https://www.hrpropninja.com
BACKEND_URL=https://api.hrpropninja.com

